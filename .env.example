# Amadeus Self-Service API — sign up at https://developers.amadeus.com
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# Use "test" while developing (fake data), "production" for real prices
AMADEUS_HOSTNAME=test

# Telegram bot — create with @BotFather, then message your bot once and
# fetch chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
